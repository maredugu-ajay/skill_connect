# Root .gitignore for full project (backend + frontend)

# Node modules
node_modules/
**/node_modules/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime data
pids/
*.pid
*.seed

# Environment files
.env
.env.*
.env.local
.env.production
.env.test

# Build / output
dist/
build/
.next/
.nuxt/
.parcel-cache/
.cache/
.vite/

# Vite / frontend build
frontend/dist/

# Coverage
coverage/
.nyc_output/

# Misc artifacts
*.tgz
*.lock-wscript
.wafpickle-

# Editor directories and files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.iml

# OS generated files
.DS_Store
Thumbs.db
desktop.ini

# Backend-specific
backend/node_modules/
backend/dist/
backend/.env
backend/logs/

# Frontend-specific
frontend/node_modules/
frontend/.env
frontend/.cache/

# Secrets and keys
*.pem
*.key
*.crt

# Coverage and test caches
.eslintcache
.jest

# Temporary files
*.tmp
~$*
